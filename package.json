{
  "name": "prompta",
  "displayName": "Prompta",
  "description": "Organize and compose AI prompts with reusable variables",
  "version": "0.2.0",
  "publisher": "padurets",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/padurets/vscode-prompta"
  },
  "homepage": "https://github.com/padurets/vscode-prompta#readme",
  "bugs": {
    "url": "https://github.com/padurets/vscode-prompta/issues"
  },
  "icon": "assets/prompta-icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "keywords": [
    "prompts",
    "ai",
    "templates",
    "prompt engineering",
    "llm",
    "chatgpt",
    "claude"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Snippets",
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "prompta",
          "title": "Prompta",
          "icon": "$(notebook)"
        }
      ]
    },
    "views": {
      "prompta": [
        {
          "id": "promptaGlobalTreeView",
          "name": "Global Prompts",
          "icon": "$(globe)",
          "contextualTitle": "Global Prompts"
        },
        {
          "id": "promptaProjectTreeView",
          "name": "Project Prompts",
          "icon": "$(root-folder)",
          "contextualTitle": "Project Prompts"
        },
        {
          "id": "promptaInspectorView",
          "name": "Prompt Inspector",
          "type": "webview",
          "contextualTitle": "Prompt Inspector"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "promptaGlobalTreeView",
        "contents": "[Create Prompt](command:prompta.global.newFile)\n[Create Folder](command:prompta.global.newFolder)"
      },
      {
        "view": "promptaProjectTreeView",
        "contents": "[Create Prompt](command:prompta.project.newFile)\n[Create Folder](command:prompta.project.newFolder)"
      }
    ],
    "commands": [
      {
        "command": "prompta.global.newFile",
        "title": "New Global Prompt",
        "category": "Prompta",
        "icon": "$(new-file)"
      },
      {
        "command": "prompta.global.newFolder",
        "title": "New Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "prompta.global.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "prompta.global.setFolder",
        "title": "Set Global Prompts Folder",
        "category": "Prompta",
        "icon": "$(folder-opened)"
      },
      {
        "command": "prompta.project.newFile",
        "title": "New Project Prompt",
        "category": "Prompta",
        "icon": "$(new-file)"
      },
      {
        "command": "prompta.project.newFolder",
        "title": "New Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "prompta.project.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "prompta.project.setFolder",
        "title": "Set Project Prompts Folder",
        "category": "Prompta",
        "icon": "$(folder-opened)"
      },
      {
        "command": "prompta.rename",
        "title": "Rename",
        "icon": "$(edit)"
      },
      {
        "command": "prompta.delete",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "prompta.copyPath",
        "title": "Copy Path"
      },
      {
        "command": "prompta.copyRelativePath",
        "title": "Copy Relative Path"
      },
      {
        "command": "prompta.openInPane",
        "title": "Open in Prompta Pane",
        "category": "Prompta"
      },
      {
        "command": "prompta.openFileInMainEditor",
        "title": "Open"
      },
      {
        "command": "prompta.toggleSidebar",
        "title": "Toggle Sidebar",
        "category": "Prompta"
      },
      {
        "command": "prompta.editGlobalEnv",
        "title": "Edit Global Variables",
        "category": "Prompta",
        "icon": "$(globe)"
      },
      {
        "command": "prompta.editProjectEnv",
        "title": "Edit Project Variables",
        "category": "Prompta",
        "icon": "$(root-folder)"
      },
      {
        "command": "prompta.reloadVariables",
        "title": "Reload Variables",
        "category": "Prompta",
        "icon": "$(refresh)"
      },
      {
        "command": "prompta.copyWithSubstitutions",
        "title": "Copy with Substitutions",
        "category": "Prompta",
        "icon": "$(copy)"
      },
      {
        "command": "prompta.useGlobalForAll",
        "title": "Switch All to Global",
        "category": "Prompta",
        "icon": "$(globe)"
      },
      {
        "command": "prompta.useProjectForAll",
        "title": "Switch All to Project",
        "category": "Prompta",
        "icon": "$(root-folder)"
      },
      {
        "command": "prompta.useCustomForAll",
        "title": "Switch All to Custom",
        "category": "Prompta",
        "icon": "$(edit)"
      },
      {
        "command": "prompta.saveAllAsGlobal",
        "title": "Save All to Global",
        "category": "Prompta",
        "icon": "$(save-all)"
      },
      {
        "command": "prompta.saveAllAsProject",
        "title": "Save All to Project",
        "category": "Prompta",
        "icon": "$(save-all)"
      }
    ],
    "submenus": [
      {
        "id": "prompta.inspectorMenu",
        "label": "Prompt Inspector Actions",
        "icon": "$(ellipsis)"
      },
      {
        "id": "prompta.globalTreeMenu",
        "label": "More Actions",
        "icon": "$(ellipsis)"
      },
      {
        "id": "prompta.projectTreeMenu",
        "label": "More Actions",
        "icon": "$(ellipsis)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "prompta.toggleSidebar"
        },
        {
          "command": "prompta.global.setFolder"
        },
        {
          "command": "prompta.project.setFolder"
        },
        {
          "command": "prompta.global.newFile"
        },
        {
          "command": "prompta.global.newFolder",
          "when": "false"
        },
        {
          "command": "prompta.global.refresh",
          "when": "false"
        },
        {
          "command": "prompta.project.newFile"
        },
        {
          "command": "prompta.project.newFolder",
          "when": "false"
        },
        {
          "command": "prompta.project.refresh",
          "when": "false"
        },
        {
          "command": "prompta.rename",
          "when": "false"
        },
        {
          "command": "prompta.delete",
          "when": "false"
        },
        {
          "command": "prompta.copyPath",
          "when": "false"
        },
        {
          "command": "prompta.copyRelativePath",
          "when": "false"
        },
        {
          "command": "prompta.openInPane",
          "when": "false"
        },
        {
          "command": "prompta.openFileInMainEditor",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "prompta.global.newFile",
          "when": "view == promptaGlobalTreeView",
          "group": "navigation@1"
        },
        {
          "command": "prompta.global.newFolder",
          "when": "view == promptaGlobalTreeView",
          "group": "navigation@2"
        },
        {
          "submenu": "prompta.globalTreeMenu",
          "when": "view == promptaGlobalTreeView",
          "group": "navigation@3"
        },
        {
          "command": "prompta.project.newFile",
          "when": "view == promptaProjectTreeView",
          "group": "navigation@1"
        },
        {
          "command": "prompta.project.newFolder",
          "when": "view == promptaProjectTreeView",
          "group": "navigation@2"
        },
        {
          "submenu": "prompta.projectTreeMenu",
          "when": "view == promptaProjectTreeView",
          "group": "navigation@3"
        },
        {
          "command": "prompta.copyWithSubstitutions",
          "when": "view == promptaInspectorView",
          "group": "navigation@1"
        },
        {
          "submenu": "prompta.inspectorMenu",
          "when": "view == promptaInspectorView",
          "group": "navigation@2"
        }
      ],
      "prompta.globalTreeMenu": [
        {
          "command": "prompta.global.refresh",
          "group": "1_main@1"
        },
        {
          "command": "prompta.global.setFolder",
          "group": "1_main@2"
        }
      ],
      "prompta.projectTreeMenu": [
        {
          "command": "prompta.project.refresh",
          "group": "1_main@1"
        },
        {
          "command": "prompta.project.setFolder",
          "group": "1_main@2"
        }
      ],
      "prompta.inspectorMenu": [
        {
          "command": "prompta.useGlobalForAll",
          "group": "1_bulk@1"
        },
        {
          "command": "prompta.useProjectForAll",
          "group": "1_bulk@2"
        },
        {
          "command": "prompta.useCustomForAll",
          "group": "1_bulk@3"
        },
        {
          "command": "prompta.saveAllAsGlobal",
          "group": "2_save@1"
        },
        {
          "command": "prompta.saveAllAsProject",
          "group": "2_save@2"
        },
        {
          "command": "prompta.editGlobalEnv",
          "group": "3_edit@1"
        },
        {
          "command": "prompta.editProjectEnv",
          "group": "3_edit@2"
        },
        {
          "command": "prompta.reloadVariables",
          "group": "4_other@1"
        }
      ],
      "view/item/context": [
        {
          "command": "prompta.openFileInMainEditor",
          "when": "view == promptaGlobalTreeView && viewItem == file",
          "group": "1_open@1"
        },
        {
          "command": "prompta.global.newFile",
          "when": "view == promptaGlobalTreeView",
          "group": "2_new@1"
        },
        {
          "command": "prompta.global.newFolder",
          "when": "view == promptaGlobalTreeView",
          "group": "2_new@2"
        },
        {
          "command": "prompta.copyPath",
          "when": "view == promptaGlobalTreeView",
          "group": "3_copy@1"
        },
        {
          "command": "prompta.copyRelativePath",
          "when": "view == promptaGlobalTreeView",
          "group": "3_copy@2"
        },
        {
          "command": "prompta.editGlobalEnv",
          "when": "view == promptaGlobalTreeView",
          "group": "4_vars@1"
        },
        {
          "command": "prompta.rename",
          "when": "view == promptaGlobalTreeView",
          "group": "9_edit@1"
        },
        {
          "command": "prompta.delete",
          "when": "view == promptaGlobalTreeView",
          "group": "9_edit@2"
        },
        {
          "command": "prompta.openFileInMainEditor",
          "when": "view == promptaProjectTreeView && viewItem == file",
          "group": "1_open@1"
        },
        {
          "command": "prompta.project.newFile",
          "when": "view == promptaProjectTreeView",
          "group": "2_new@1"
        },
        {
          "command": "prompta.project.newFolder",
          "when": "view == promptaProjectTreeView",
          "group": "2_new@2"
        },
        {
          "command": "prompta.copyPath",
          "when": "view == promptaProjectTreeView",
          "group": "3_copy@1"
        },
        {
          "command": "prompta.copyRelativePath",
          "when": "view == promptaProjectTreeView",
          "group": "3_copy@2"
        },
        {
          "command": "prompta.editProjectEnv",
          "when": "view == promptaProjectTreeView",
          "group": "4_vars@1"
        },
        {
          "command": "prompta.rename",
          "when": "view == promptaProjectTreeView",
          "group": "9_edit@1"
        },
        {
          "command": "prompta.delete",
          "when": "view == promptaProjectTreeView",
          "group": "9_edit@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "prompta.openFileInMainEditor",
        "key": "alt+enter",
        "when": "focusedView == promptaGlobalTreeView || focusedView == promptaProjectTreeView"
      }
    ],
    "configuration": {
      "title": "Prompta",
      "properties": {
        "prompta.globalFolder": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the global prompts folder. If empty, defaults to ~/Prompta/prompts."
        },
        "prompta.projectFolder": {
          "type": "string",
          "default": ".prompta",
          "description": "Relative path (from workspace root) to the project prompts folder."
        },
        "prompta.fontSize": {
          "type": "number",
          "default": 14,
          "minimum": 8,
          "maximum": 32,
          "description": "Font size in the Prompt Inspector panel (px)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@vscode/vsce": "^3.9.0",
    "typescript": "^5.3.0"
  }
}
